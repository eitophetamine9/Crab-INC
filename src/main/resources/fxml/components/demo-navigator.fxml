<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<HBox alignment="CENTER" spacing="12" style="-fx-background-color: rgba(245, 248, 252, 0.94); -fx-background-radius: 8; -fx-padding: 12 16 12 16;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="crab.features.demo.presentation.components.DemoNavigatorController">
    <Button fx:id="menuButton" mnemonicParsing="false" onAction="#showMenu" prefWidth="120" text="Main Menu" />
    <Button fx:id="boxButton" mnemonicParsing="false" onAction="#showBox" prefWidth="120" text="Red Square" />
    <Button fx:id="bunnyButton" mnemonicParsing="false" onAction="#showBunny" prefWidth="120" text="Bunny" />
</HBox>
