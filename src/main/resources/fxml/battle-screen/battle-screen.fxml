<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainLayout" prefHeight="720.0" prefWidth="1024.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="crab.features.gameplay.presentation.GameplayScreenController">
   <top>
      <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-border-color: black;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Button fx:id="settingsBtn" mnemonicParsing="false" onAction="#handleSettings" text="Settings" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="topGoldLabel" text="Gold: 0" />
         </children>
      </HBox>
   </top>
   <center>
      <VBox fx:id="centerStack" alignment="TOP_CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="20.0" />
         </padding>
         <children>
            <Label fx:id="phasePromptLabel" style="-fx-border-color: black; -fx-padding: 5;" text="" />
            <HBox fx:id="battlefieldArea" alignment="TOP_CENTER" spacing="50.0">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </center>
   <bottom>
      <AnchorPane prefHeight="250.0" style="-fx-border-color: black;" BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="heroAvatar" alignment="CENTER" prefHeight="150.0" prefWidth="120.0" spacing="5.0" style="-fx-border-color: black;" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="30.0">
               <children>
                  <Label fx:id="heroClassLabel" text="CLASS" />
                  <Label fx:id="heroNameLabel" text="Player" />
                  <Label fx:id="heroWealthLabel" text="Wealth: 0" />
                  <Label fx:id="heroReputationLabel" text="Reputation: 0" />
                  <Label fx:id="heroInfamyLabel" text="Infamy: 0" />
               </children>
            </VBox>
            <HBox fx:id="handArea" alignment="BOTTOM_CENTER" spacing="10.0" style="-fx-border-color: black; -fx-padding: 5;" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="200.0" />
            <Button fx:id="endTurnBtn" mnemonicParsing="false" text="END PHASE" AnchorPane.bottomAnchor="80.0" AnchorPane.rightAnchor="30.0" />
            <VBox alignment="CENTER" style="-fx-border-color: black; -fx-padding: 5;" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="472.0">
               <children>
                  <Label fx:id="roundGemLabel" text="Round: 1" />
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </bottom>
</BorderPane>
