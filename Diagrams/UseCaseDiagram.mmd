    style UC_Login fill:#fcf0f2,stroke:#f43f5e,stroke-width:1px
    style UC_Signup fill:#fcf0f2,stroke:#f43f5e,stroke-width:1px
    style UC_Guest fill:#fcf0f2,stroke:#f43f5e,stroke-width:1px

    %% Style Mgmt Use Cases
    style UC_StartSession fill:#ecfdf5,stroke:#10b981,stroke-width:1px
    style UC_LoadSession fill:#ecfdf5,stroke:#10b981,stroke-width:1px
    style UC_ViewStats fill:#ecfdf5,stroke:#10b981,stroke-width:1px
    style UC_GameOver fill:#ecfdf5,stroke:#10b981,stroke-width:1px

    %% Style Gameplay Use Cases
    style UC_DrawCard fill:#eff6ff,stroke:#3b82f6,stroke-width:1px
    style UC_UpgradeBuild fill:#eff6ff,stroke:#3b82f6,stroke-width:1px
    style UC_PlayAction fill:#eff6ff,stroke:#3b82f6,stroke-width:1px
    style UC_ResolveTurn fill:#eff6ff,stroke:#3b82f6,stroke-width:1px

    %% Style Specialized Actions
    style UC_AltruistSig fill:#faf5ff,stroke:#a855f7,stroke-width:1.5px
    style UC_OppSig fill:#faf5ff,stroke:#a855f7,stroke-width:1.5px
    style UC_SaboteurSig fill:#faf5ff,stroke:#a855f7,stroke-width:1.5px
    style UC_ShopInteract fill:#faf5ff,stroke:#a855f7,stroke-width:1.5px
